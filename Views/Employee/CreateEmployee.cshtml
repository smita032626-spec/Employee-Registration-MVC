@model EmployeeManagementCRUD.Models.EmployeeProperties

@{
    ViewBag.Title = "Create Employee";
}

<h2>Create Employee</h2>

@using (Html.BeginForm("CreateEmployee", "Employee", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    <div>
        <label>Name</label>
        @Html.TextBoxFor(m => m.Name, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Name)
    </div>

    <div>
        <label>Email</label>
        @Html.TextBoxFor(m => m.Email, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Email)
    </div>

    <div>
        <label>Phone</label>
        @Html.TextBoxFor(m => m.PhoneNumber, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.PhoneNumber)
    </div>

    <div>
        <label>DOB</label>
        @Html.TextBoxFor(m => m.DOB, new { type = "date", @class = "form-control" })
    </div>

    <div>
        <label>Address</label>
        @Html.TextAreaFor(m => m.Address, new { @class = "form-control", rows = 3 })
    </div>

    <div>
        <label>City</label>
        @Html.DropDownListFor(m => m.CityId, ViewBag.CityList as SelectList, "Select City", new { @id = "CityId", @class = "form-control" })
    </div>

    <div>
        <label>District</label>
        @Html.DropDownListFor(m => m.DistrictId, new SelectList(Enumerable.Empty<SelectListItem>()), "Select District", new { @id = "DistrictId", @class = "form-control" })
    </div>

    <div>
        <label>Taluka</label>
        @Html.DropDownListFor(m => m.TalukaId, new SelectList(Enumerable.Empty<SelectListItem>()), "Select Taluka", new { @id = "TalukaId", @class = "form-control" })
    </div>

    <div>
        <label>Department</label>
        @Html.DropDownListFor(m => m.DepartmentId, ViewBag.DepartmentList as SelectList, "Select Department", new { @class = "form-control" })
    </div>

    <div>
        <label>Designation</label>
        @Html.DropDownListFor(m => m.DesignationId, ViewBag.DesignationList as SelectList, "Select Designation", new { @class = "form-control" })
    </div>

    <div>
        <label>Pincode</label>
        @Html.TextBoxFor(m => m.Pincode, new { @class = "form-control" })
    </div>

    <div>
        <label>Upload File</label>
        <input type="file" name="UploadFile" class="form-control" />
    </div>

    <div>
        <label>Is Active</label>
        @Html.CheckBoxFor(m => m.IsActive)
    </div>

    <br />
    <input type="submit" value="Save Employee" class="btn btn-primary" />
}

@section Scripts {
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>

    <script>
        $(document).ready(function () {

            // City → District cascading
            $("#CityId").change(function () {
                var cityId = $(this).val();
                $("#DistrictId").empty();
                $("#TalukaId").empty();
                if (cityId) {
                    $.getJSON('/Employee/GetDistrict', { CityId: cityId }, function (data) {
                        $("#DistrictId").append('<option value="">Select District</option>');
                        $.each(data, function (i, item) {
                            $("#DistrictId").append('<option value="' + item.Value + '">' + item.Text + '</option>');
                        });
                    });
                }
            });

            // District → Taluka cascading
            $("#DistrictId").change(function () {
                var districtId = $(this).val();
                $("#TalukaId").empty();
                if (districtId) {
                    $.getJSON('/Employee/GetTaluka', { DistrictId: districtId }, function (data) {
                        $("#TalukaId").append('<option value="">Select Taluka</option>');
                        $.each(data, function (i, item) {
                            $("#TalukaId").append('<option value="' + item.Value + '">' + item.Text + '</option>');
                        });
                    });
                }
            });

        });
    </script>
}